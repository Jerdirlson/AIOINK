# Copia este archivo a .env y rellena tus llaves de Belvo.
# NUNCA subas el .env real al repositorio (ya está en .gitignore).

# Obligatorias — genera estas llaves en https://dashboard.belvo.com
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=

# sandbox = bancos de prueba (gratis) | production = tu banco real (requiere cuenta aprobada)
BELVO_ENV=sandbox

# Opcional: para crear un link de prueba en sandbox.
# Consulta las credenciales de prueba vigentes en:
# https://developers.belvo.com/docs/test-in-sandbox
BELVO_TEST_INSTITUTION=erebor_co_retail
BELVO_TEST_USERNAME=
BELVO_TEST_PASSWORD=
